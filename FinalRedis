package com.example.redis.auth;

import software.amazon.awssdk.auth.credentials.AwsCredentials;
import software.amazon.awssdk.http.SdkHttpFullRequest;
import software.amazon.awssdk.http.SdkHttpMethod;
import software.amazon.awssdk.http.auth.aws.signer.AwsV4FamilyHttpSigner;
import software.amazon.awssdk.http.auth.aws.signer.AwsV4HttpSigner;
import software.amazon.awssdk.http.auth.spi.signer.SignedRequest;
import software.amazon.awssdk.regions.Region;

import java.time.Duration;

/**
 * Builds an AWS SigV4 presigned URL accepted by ElastiCache / Valkey IAM auth
 * as the password (a.k.a. "IAM auth token").
 *
 * Thread-safe and immutable -- reuse a single instance.
 */
public final class IamAuthTokenRequest {

    private static final String SERVICE_NAME           = "elasticache";
    private static final String ACTION                 = "connect";
    private static final String RESOURCE_TYPE_VALUE    = "ServerlessCache";
    private static final Duration TOKEN_EXPIRY         = Duration.ofMinutes(15);
    private static final String SIGNING_PROTOCOL       = "http";
    private static final String SCHEME_PREFIX_TO_STRIP = "http://";

    private final String userId;
    private final String cacheName;
    private final Region region;
    private final boolean serverless;
    private final AwsV4HttpSigner signer;

    public IamAuthTokenRequest(String userId, String cacheName, Region region, boolean serverless) {
        this.userId = userId;
        this.cacheName = cacheName;
        this.region = region;
        this.serverless = serverless;
        this.signer = AwsV4HttpSigner.create();
    }

    public String toSignedRequestUri(AwsCredentials credentials) {
        SdkHttpFullRequest.Builder requestBuilder = SdkHttpFullRequest.builder()
                .method(SdkHttpMethod.GET)
                .protocol(SIGNING_PROTOCOL)
                .host(cacheName)
                .encodedPath("/")
                .appendRawQueryParameter("Action", ACTION)
                .appendRawQueryParameter("User", userId);

        if (serverless) {
            requestBuilder.appendRawQueryParameter("ResourceType", RESOURCE_TYPE_VALUE);
        }

        SdkHttpFullRequest request = requestBuilder.build();

        SignedRequest signed = signer.sign(r -> r
                .identity(credentials)
                .request(request)
                .putProperty(AwsV4HttpSigner.SERVICE_SIGNING_NAME, SERVICE_NAME)
                .putProperty(AwsV4HttpSigner.REGION_NAME, region.id())
                .putProperty(AwsV4FamilyHttpSigner.AUTH_LOCATION,
                             AwsV4FamilyHttpSigner.AuthLocation.QUERY_STRING)
                .putProperty(AwsV4HttpSigner.EXPIRATION_DURATION, TOKEN_EXPIRY)
                .putProperty(AwsV4HttpSigner.PAYLOAD_SIGNING_ENABLED, Boolean.TRUE)
        );

        return ((SdkHttpFullRequest) signed.request())
                .getUri().toString()
                .replace(SCHEME_PREFIX_TO_STRIP, "");
    }
}

