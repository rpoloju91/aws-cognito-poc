package com.example.redis;

import com.example.redis.auth.CachingIamAuthTokenProvider;
import com.example.redis.auth.IamAuthTokenRequest;
import io.lettuce.core.RedisClient;
import io.lettuce.core.RedisCredentials;
import io.lettuce.core.RedisCredentialsProvider;
import io.lettuce.core.RedisURI;
import io.lettuce.core.api.StatefulRedisConnection;
import io.lettuce.core.api.sync.RedisCommands;
import jakarta.annotation.PostConstruct;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import reactor.core.publisher.Mono;
import software.amazon.awssdk.auth.credentials.AwsCredentialsProvider;
import software.amazon.awssdk.auth.credentials.DefaultCredentialsProvider;
import software.amazon.awssdk.regions.Region;

@Configuration
public class RedisConfig {

    private static final Logger log = LoggerFactory.getLogger(RedisConfig.class);

    @Value("${redis.host}")                  private String host;
    @Value("${redis.port}")                  private int port;
    @Value("${redis.user-id}")               private String userId;
    @Value("${redis.serverless-cache-name}") private String cacheName;
    @Value("${redis.region}")                private String region;
    @Value("${redis.serverless:true}")       private boolean serverless;

    @PostConstruct
    public void printRedisConfig() {
        log.info("================================");
        log.info("REDIS HOST  : {}", host);
        log.info("REDIS PORT  : {}", port);
        log.info("REDIS USER  : {}", userId);
        log.info("REDIS CACHE : {}", cacheName);
        log.info("REDIS REGION: {}", region);
        log.info("SERVERLESS  : {}", serverless);
        log.info("================================");
    }

    @Bean
    public AwsCredentialsProvider awsCredentialsProvider() {
        return DefaultCredentialsProvider.create();
    }

    @Bean
    public IamAuthTokenRequest iamAuthTokenRequest() {
        return new IamAuthTokenRequest(userId, cacheName, Region.of(region), serverless);
    }

    @Bean
    public CachingIamAuthTokenProvider cachingTokenProvider(IamAuthTokenRequest req,
                                                            AwsCredentialsProvider creds) {
        return new CachingIamAuthTokenProvider(req, creds);
    }

    @Bean(destroyMethod = "shutdown")
    public RedisClient redisClient(CachingIamAuthTokenProvider tokens) {
        RedisCredentialsProvider credsProvider = () -> Mono.fromCallable(
                () -> RedisCredentials.just(userId, tokens.getToken()));

        RedisURI uri = RedisURI.builder()
                .withHost(host)
                .withPort(port)
                .withSsl(true)
                .withAuthentication(credsProvider)
                .build();

        return RedisClient.create(uri);
    }

    @Bean(destroyMethod = "close")
    public StatefulRedisConnection<String, String> redisConnection(RedisClient client) {
        return client.connect();
    }

    @Bean
    public RedisCommands<String, String> redisCommands(StatefulRedisConnection<String, String> conn) {
        return conn.sync();
    }
}
